          "children": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/__schema0"
            }
          },
          "allowAdditionalChildren": {
            "type": "boolean"
          }
        },
        "required": [
          "name"
        ],
        "additionalProperties": false
      }
