                "warning",
                "off"
              ]
            },
            {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "off"
                  ]
                }
              },
              "required": [
                "severity"
              ],
              "additionalProperties": false
            }
          ]
        },
        "unescapedEntities": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "error",
                "warning",
                "off"
              ]
            },
            {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "off"
                  ]
                }
              },
              "required": [
                "severity"
              ],
              "additionalProperties": false
            }
          ]
        },
        "preferMustacheComments": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "error",
                "warning",
                "off"
              ]
            },
            {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "off"
