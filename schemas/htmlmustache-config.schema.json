{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "printWidth": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "indentSize": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "mustacheSpaces": {
      "type": "boolean"
    },
    "noBreakDelimiters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "minLength": 1
          },
          "end": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "start",
          "end"
        ],
        "additionalProperties": false
      }
    },
    "customTags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "display": {
            "type": "string",
            "enum": [
              "block",
              "inline",
              "inline-block",
              "table-row",
              "table-cell",
              "table",
              "table-row-group",
              "table-header-group",
              "table-footer-group",
              "table-column",
              "table-column-group",
              "table-caption",
              "list-item",
              "ruby",
              "ruby-base",
              "ruby-text",
              "none"
