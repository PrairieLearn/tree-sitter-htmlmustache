        "type": "string",
        "minLength": 1
      }
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "nestedDuplicateSections": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "error",
                "warning",
                "off"
              ]
            },
            {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "off"
                  ]
                }
              },
              "required": [
                "severity"
              ],
              "additionalProperties": false
            }
          ]
        },
        "unquotedMustacheAttributes": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "error",
                "warning",
                "off"
              ]
            },
            {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "off"
                  ]
                }
              },
              "required": [
                "severity"
              ],
              "additionalProperties": false
