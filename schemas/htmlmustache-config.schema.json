          },
          "languageAttribute": {
            "type": "string"
          },
          "languageMap": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "languageDefault": {
            "type": "string"
          },
          "indent": {
            "type": "string",
            "enum": [
              "never",
              "always",
              "attribute"
            ]
          },
          "indentAttribute": {
            "type": "string"
          },
          "schema": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "properties": {},
                "additionalProperties": {}
              }
            ]
