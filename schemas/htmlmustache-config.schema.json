              "type": "string",
              "enum": [
                "error",
                "warning",
                "off"
              ]
            },
            {
              "type": "object",
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": [
                    "error",
                    "warning",
                    "off"
                  ]
                }
