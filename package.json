{
  "name": "@reteps/tree-sitter-htmlmustache",
  "version": "1.2.0",
  "description": "HTML with Mustache/Handlebars template syntax grammar for tree-sitter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reteps/tree-sitter-htmlmustache.git"
  },
  "license": "MIT",
  "author": {
    "name": "Peter Stenger"
  },
  "main": "bindings/node",
  "bin": {
    "htmlmustache": "dist/cli/main.js"
  },
  "types": "bindings/node",
  "exports": {
    ".": {
      "types": "./bindings/node/index.d.ts",
      "default": "./bindings/node/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.mjs"
    },
    "./linter": {
      "types": "./dist/linter/index.d.ts",
      "import": "./dist/linter/index.mjs"
    },
    "./formatter": {
      "types": "./dist/formatter/index.d.ts",
      "import": "./dist/formatter/index.mjs"
    },
    "./wasm": "./tree-sitter-htmlmustache.wasm",
    "./tree-sitter-htmlmustache.wasm": "./tree-sitter-htmlmustache.wasm",
    "./package.json": "./package.json"
  },
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "html",
    "mustache",
    "handlebars"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**/*.c",
    "src/**/*.h",
    "src/node-types.json",
    "src/grammar.json",
    "dist/**",
    "*.wasm"
  ],
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-errors": "^3.0.0",
    "ajv-i18n": "^4.2.0",
    "chalk": "^5.6.2",
    "editorconfig": "^3.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "web-tree-sitter": "^0.26.5"
  },
  "peerDependencies": {
    "node-addon-api": "^8.2.2",
    "node-gyp-build": "^4.8.2",
    "prettier": "^3.0.0",
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "node-addon-api": {
      "optional": true
    },
    "node-gyp-build": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.14.0",
    "eslint-config-treesitter": "^1.0.2",
    "parsel-js": "^1.2.2",
    "prebuildify": "^6.0.1",
    "prettier": "^3.8.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.26.5",
    "tsx": "^4.20.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter",
      "tree-sitter-cli"
    ]
  },
  "scripts": {
    "install": "node-gyp-build || exit 0",
    "build": "tree-sitter build --wasm",
    "build:js": "node esbuild.config.mjs && tsc -p js/tsconfig.json",
    "prepack": "tree-sitter build --wasm && npm run generate:ast-types && npm run build:js",
    "check": "node dist/cli/main.js check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "tree-sitter test && node --test bindings/node/*_test.js",
    "test:js": "vitest run",
    "typecheck": "tsc -p js/tsconfig.json --noEmit",
    "generate:ast-types": "tsx scripts/generate-ast-types.ts",
    "generate:rule-docs": "tsx scripts/generate-rule-docs.ts"
  }
}
